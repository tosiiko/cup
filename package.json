{
  "name": "@tosiiko/cup",
  "version": "0.2.4",
  "description": "CUP universal UI runtime for protocol-driven browser rendering",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cup": "bin/cup.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "scaffolds/python-standard/.gitignore",
    "scaffolds/python-standard/README.md",
    "scaffolds/python-standard/index.html",
    "scaffolds/python-standard/server.py",
    "scaffolds/python-standard/app/__init__.py",
    "scaffolds/python-standard/app/actions.py",
    "scaffolds/python-standard/app/config.py",
    "scaffolds/python-standard/app/cup_bridge.py",
    "scaffolds/python-standard/app/data.py",
    "scaffolds/python-standard/app/routes.py",
    "scaffolds/python-standard/app/security.py",
    "scaffolds/python-standard/app/server.py",
    "scaffolds/python-standard/app/sessions.py",
    "scaffolds/python-standard/app/templates.py",
    "scaffolds/python-standard/app/views.py",
    "scaffolds/python-standard/static/app.css",
    "scaffolds/python-standard/static/app.js",
    "scaffolds/python-standard/templates/pages/guide.html",
    "scaffolds/python-standard/templates/pages/welcome.html",
    "scaffolds/python-standard/templates/shell.html",
    "schema",
    "styles",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/uiview.v1.json": "./schema/uiview.v1.json",
    "./styles/reference.css": "./styles/reference.css"
  },
  "sideEffects": [
    "./styles/reference.css"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "check": "npm run build && npm run test && npm run pack:check",
    "demo:smoke": "node scripts/demo-smoke.mjs",
    "demo:build": "vite build examples/demo --outDir ../../dist-demo",
    "demo:dev": "vite examples/demo",
    "pack:check": "npm run build && node scripts/pack-check.mjs",
    "starter:smoke": "node scripts/starter-smoke.mjs",
    "test": "npm run test:ts && npm run test:python && npm run test:go",
    "test:go": "cd adapters/go && GOCACHE=/tmp/cup-go-cache go test ./...",
    "test:python": "python3 -m unittest discover -s adapters/python/tests -p 'test_*.py'",
    "test:ts": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.21.5",
    "jsdom": "^24.1.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.1"
  }
}
