{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node", "vitest/globals"],
    "lib": ["ES2020", "DOM"]
  },
  "include": ["src", "tests", "examples", "vitest.config.ts"]
}
